# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dynamicwepubmonitor
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM API (for AI analysis)
LLM_API_URL=https://api.example.com/v1/chat/completions
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o

# Application
APP_ENV=development
DEBUG=true
MEDIA_ROOT=media
MEDIA_URL_PREFIX=/media
FRONTEND_DIST_PATH=frontend/dist
COLLECTOR_HEALTH_CHECK_HOUR=23
COLLECTOR_HEALTH_CHECK_MINUTE=30

# DynamicWeightAdjuster Configuration
WEIGHT_FREQUENCY_RATIO=0.35
WEIGHT_RECENCY_RATIO=0.25
WEIGHT_RELEVANCE_RATIO=0.25
WEIGHT_STABILITY_RATIO=0.15

TIER_THRESHOLD_TIER1=80
TIER_THRESHOLD_TIER2=65
TIER_THRESHOLD_TIER3=50
TIER_THRESHOLD_TIER4=35

CHECK_INTERVAL_TIER1=24
CHECK_INTERVAL_TIER2=48
CHECK_INTERVAL_TIER3=72
CHECK_INTERVAL_TIER4=144
CHECK_INTERVAL_TIER5=336

# Alert Thresholds
HIGH_RELEVANCE_THRESHOLD=0.8
AI_CONSECUTIVE_LOW_THRESHOLD=3

# QR Code
QR_CODE_EXPIRE_SECONDS=180
WEREAD_PLATFORM_URL=
WEREAD_PLATFORM_TIMEOUT_SECONDS=30
WEREAD_PLATFORM_EXPIRE_FAILURE_THRESHOLD=2
WEREAD_PLATFORM_CREDENTIAL_COOLDOWN_MINUTES=60

# Default admin bootstrap
ENSURE_DEFAULT_ADMIN=true
DEFAULT_ADMIN_ALIAS=admin
DEFAULT_ADMIN_EMAIL=admin@admin.com
DEFAULT_ADMIN_PASSWORD=admin123
