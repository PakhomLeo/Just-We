# Copy this file to .env.docker only if you want deployment-specific overrides.
# docker-compose.yml is self-contained and works without this file.
#
# Docker Compose automatically reads a root .env file for interpolation. Just-We
# uses JUST_WE_* override names here so local development .env values are not
# accidentally injected into the Docker stack.

# Required in production. The compose file has a fallback only for local trials.
JUST_WE_JWT_SECRET_KEY=replace-with-a-long-random-secret

# Optional default admin bootstrap. Change the password before exposing the app.
JUST_WE_ENSURE_DEFAULT_ADMIN=true
JUST_WE_DEFAULT_ADMIN_ALIAS=admin
JUST_WE_DEFAULT_ADMIN_EMAIL=admin@admin.com
JUST_WE_DEFAULT_ADMIN_PASSWORD=replace-before-production

# Optional external AI provider.
JUST_WE_LLM_API_URL=https://api.example.com/v1/chat/completions
JUST_WE_LLM_API_KEY=
JUST_WE_LLM_MODEL=gpt-4o

# Optional external WeRead-compatible platform.
JUST_WE_WEREAD_PLATFORM_URL=
JUST_WE_WEREAD_PLATFORM_TIMEOUT_SECONDS=30
JUST_WE_WEREAD_PLATFORM_EXPIRE_FAILURE_THRESHOLD=2
JUST_WE_WEREAD_PLATFORM_CREDENTIAL_COOLDOWN_MINUTES=60

# Internal Docker defaults used by docker-compose.yml:
# JUST_WE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/dynamicwepubmonitor
# JUST_WE_REDIS_URL=redis://redis:6379/0
# JUST_WE_APP_ENV=production
# JUST_WE_DEBUG=false
